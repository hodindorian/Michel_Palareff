# Copie ce fichier en .env et remplis avec tes vraies valeurs.
# docker compose lit automatiquement le .env à côté de docker-compose.yml.

# "pg" en local (PostgreSQL) ou "mysql2" sur le serveur (MariaDB/MySQL).
DB_CLIENT=pg
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=michel_palareff
DB_PASSWORD=change-me
DB_NAME=michel_palareff

# Secret utilisé pour signer les sessions (JWT). Génère une vraie valeur
# aléatoire avant de déployer, par ex. avec `openssl rand -hex 32`.
JWT_SECRET=change-me-too
